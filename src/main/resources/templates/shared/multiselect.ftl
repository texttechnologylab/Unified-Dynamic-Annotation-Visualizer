    <div class="dv-dropdown-container">
      <div class="dv-multiselect" tabindex="0">
        <input type="hidden">
        <div class="dv-multiselect-pills"></div>
        <i class="bi bi-chevron-expand"></i>
      </div>
      <div class="dv-dropdown"></div>
    </div>
  </template>
</#macro>
